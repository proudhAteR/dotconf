{
    // ──────────────────────────────────────────────────────────────────────────────
    // 🖼️ UI & THEME
    // ──────────────────────────────────────────────────────────────────────────────
    "theme": "One Dark",
    "session": {
        "trust_all_worktrees": true
    },
    "icon_theme": "Light Charmed Icons",
    "use_system_prompts": true,
    "ui_font_family": "IBM Plex Mono",
    "buffer_font_family": "IBM Plex Mono",
    "buffer_font_fallbacks": [
        "JetBrainsMono Nerd Font"
    ],
    "buffer_font_features": {
        "calt": false,
        "liga": false
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // 🖼️ UI/COMPONENTS
    // ──────────────────────────────────────────────────────────────────────────────
    "scrollbar": {
        "show": "never",
    },
    "tabs": {
        "file_icons": true,
        "show_close_button": "hidden",
        "git_status": true,
        "activate_on_close": "left_neighbour",
        "show_diagnostics": "errors"
    },
    "toolbar": {
        "breadcrumbs": false,
        "quick_actions": false,
        "code_actions": false,
    },
    "file_finder": {
        "modal_max_width": "small",
        "include_ignored": "all",
        "file_icons": true,
        "skip_focus_for_active_in_search": true
    },
    "gutter": {
        "min_line_number_digits": 0,
        "folds": true,
    },
    "title_bar": {
        "show_onboarding_banner": false,
        "show_menus": true
    },
    "debugger": {
        "dock": "left"
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // ✍️ EDITOR BEHAVIOR & UX
    // ──────────────────────────────────────────────────────────────────────────────
    "base_keymap": "VSCode",
    "cursor_shape": "block",
    "cursor_blink": true,
    "hide_mouse": "on_typing_and_movement",
    "current_line_highlight": "none",
    "rounded_selection": true,
    "show_whitespaces": "selection",
    "scroll_beyond_last_line": "off",
    "double_click_in_multibuffer": "open",
    "confirm_quit": false,
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // 🧠 INTELLISENSE & AI
    // ──────────────────────────────────────────────────────────────────────────────
    "enable_language_server": true,
    "auto_signature_help": false,
    "show_completions_on_input": true,
    "completions": {
        "words_min_length": 4,
    },
    "edit_predictions": {
        "provider": "none",
    },
    "agent_servers": {
        "codex-acp": {
            "type": "registry"
        }
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // 🧰 FORMATTING & CODING STANDARDS
    // ──────────────────────────────────────────────────────────────────────────────
    "tab_size": 4,
    "format_on_save": "on",
    "formatter": "language_server",
    "remove_trailing_whitespace_on_save": true,
    "ensure_final_newline_on_save": true,
    "use_on_type_format": true,
    "code_actions_on_format": {
        "source.fixAll": true,
        "source.fixAll.ts": true,
        "source.organizeImports": true
    },
    "inlay_hints": {
        "show_background": false,
        "enabled": false,
        "show_type_hints": true,
    },
    "soft_wrap": "preferred_line_length",
    "preferred_line_length": 120,
    "allow_rewrap": "in_comments",
    "auto_indent": "syntax_aware",
    "auto_indent_on_paste": true,
    "always_treat_brackets_as_autoclosed": true,
    "colorize_brackets": true,
    // ──────────────────────────────────────────────────────────────────────────────
    // 🌲 PANEL CONFIGURATIONS
    // ──────────────────────────────────────────────────────────────────────────────
    "project_panel": {
        "dock": "left",
        "auto_fold_dirs": false,
        "git_status": true,
        "hide_root": true,
        "hide_gitignore": false,
        "indent_guides": {
            "show": "always",
        },
        "entry_spacing": "comfortable",
        "button": false,
        "scrollbar": {
            "show": "never"
        }
    },
    "git_panel": {
        "tree_view": true,
        "show_count_badge": true,
        "dock": "right",
        "file_icons": true
    },
    "outline_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "dock": "right",
    },
    "notification_panel": {
        "dock": "right",
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // 🌿 GIT SETTINGS
    // ──────────────────────────────────────────────────────────────────────────────
    "git": {
        "blame": {
            "show_avatar": true,
        },
        "git_gutter": "tracked_files",
        "inline_blame": {
            "enabled": true,
            "show_commit_summary": false,
        },
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // 🧩 LANGUAGE SPECIFIC & LSP
    // ──────────────────────────────────────────────────────────────────────────────
    "languages": {
        "CSS": {
            "language_servers": [
                "tailwindcss-intellisense-css",
                "!vscode-css-language-server",
            ],
        },
        "Swift": {
            "enable_language_server": true,
            "language_servers": [
                "sourcekit-lsp"
            ],
            "format_on_save": "on",
        },
        "PHP": {
            "language_servers": [
                "intelephense",
                "!phpactor",
                "!phptools",
                "!emmet",
            ],
            "format_on_save": "on",
            "formatter": "language_server",
        },
        "Latte": {
            "language_servers": [
                "tailwindcss-language-server",
                "emmet",
                "intelephense",
            ],
        },
        "CSharp": {
            "language_servers": [
                "!omnisharp",
                "roslyn",
            ]
        },
    },
    "lsp": {
        "tailwindcss-language-server": {
            "settings": {
                "classFunctions": [
                    "tw",
                    "clsx",
                    "tw\\.[a-z-]+"
                ],
                "experimental": {
                    "classRegex": [
                        // Matches: class => "..." or class: "..." (Latte params/arrays)
                        "(?:class|className)\\s*(?:=>|:)\\s*[\"']([^\"']*)[\"']",
                        // Matches: $class = "..." or $myClass = "..." (Latte variables)
                        "\\$[a-zA-Z]*[Cc]lass(?:Name)?\\s*=\\s*[\"']([^\"']*)[\"']",
                    ],
                },
                "emmetCompletions": true,
                "includeLanguages": {
                    "latte": "html",
                    "pug": "html",
                },
                "hovers": true,
            },
        },
        "sourcekit-lsp": {
            "binary": {
                "path": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/sourcekit-lsp",
            },
        },
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                    "format": {
                        "semicolons": "insert",
                        "trimTrailingWhitespace": true,
                        "trimTrailingCommas": true,
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                    "format": {
                        "semicolons": "insert",
                        "trimTrailingWhitespace": true,
                    },
                },
            },
        },
        "yaml-language-server": {
            "settings": {
                "yaml": {
                    "customTags": [
                        "!env scalar",
                        "!env sequence",
                        "!env mapping"
                    ],
                },
            },
        },
    },
    // ──────────────────────────────────────────────────────────────────────────────
    // 📂 FILE TYPES & EXCLUSIONS
    // ──────────────────────────────────────────────────────────────────────────────
    "file_types": {
        "tailwindcss": [
            "**/tailwind.css",
            "**/tailwind/**"
        ],
        "php": [
            "*.php"
        ],
        "pug": [
            "*.pug",
            "*.jade"
        ],
        "latte": [
            "*.latte"
        ],
    },
    "file_scan_exclusions": [
        "**/node_modules/**",
        "**/.output/**",
        "**/.nuxt/**",
        "**/.next/**",
        "**/dist/**",
        "**/build/**",
        "**/.turbo/**",
        "**/vendor/**",
        "**/.git/**",
        "**/.cache/**",
        "**/coverage/**",
        "**/*.log",
        "**/*.lock",
        "**/*.d.ts",
        "**/.DS_Store",
        "**/.idea/**",
        "**/*-lock.json",
        "**/*.csproj",
        "**/*.sln",
        "**/.build/**",
        "**/bin/**",
        "**/obj/**",
        "**/.swiftpm/**",
        "**/*.tsbuildinfo"
    ],
    // ──────────────────────────────────────────────────────────────────────────────
    // 💻 TERMINAL
    // ──────────────────────────────────────────────────────────────────────────────
    "terminal": {
        "scrollbar": {
            "show": "never",
        },
        "toolbar": {
            "breadcrumbs": false,
        },
        "alternate_scroll": "on",
        "blinking": "on",
        "copy_on_select": true,
        "keep_selection_on_copy": true,
        "button": false,
        "working_directory": "current_project_directory",
    },
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
}
